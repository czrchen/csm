---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-mark">C</span>
        <span class="brand-text">Cipta Success</span>
      </a>
      <p>Goat milk &amp; beverage OEM manufacturer in Seremban since 2005 — your recipe, your brand, on the Tok' Ali line.</p>
      <div class="socials">
        <a href="#" aria-label="Facebook">Facebook</a>
        <a href="#" aria-label="WhatsApp">WhatsApp</a>
        <a href="#" aria-label="Instagram">Instagram</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <a href="/">Home</a>
      <a href="/about">About Us</a>
      <a href="/products">Products</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Products</h4>
      <a href="/products">Goat Milk Powder</a>
      <a href="/products">3-in-1 Coffee</a>
      <a href="/products">Chocolate &amp; Tea</a>
      <a href="/products">OEM &amp; Private Label</a>
    </div>

    <div class="footer-col">
      <h4>Get in touch</h4>
      <p class="muted">Lot 39, Jalan Lombong Emas 5, Kawasan Industri Ringan Tun Dr Ismail, 70200 Seremban, Negeri Sembilan</p>
      <a href="tel:+60198123025">+6019-812 3025</a>
      <a href="mailto:admin@ciptasuccess.com.my">admin@ciptasuccess.com.my</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} Cipta Success Marketing (CSM) · Since 2005</span>
    <span>Seremban, Negeri Sembilan, Malaysia</span>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--navy);
    color: #D6E2D2;
    margin-top: 110px;
    padding: 70px 0 30px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1.4fr;
    gap: 40px;
  }
  .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .brand-mark { display: grid; place-items: center; width: 50px; height: 50px; background: var(--red); color: var(--gold); border-radius: 12px; font-family: var(--font-display); font-weight: 800; font-size: 1.5rem; }
  .brand-text { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; color: #fff; letter-spacing: -0.02em; }
  .footer-brand p { color: #9FB39A; max-width: 320px; font-size: .95rem; line-height: 1.6; }

  .socials { display: flex; gap: 18px; margin-top: 22px; }
  .socials a {
    font-size: .88rem; font-weight: 500; color: #9FB39A;
    transition: color .2s ease;
  }
  .socials a:hover { color: var(--gold); }

  .footer-col h4 {
    font-family: var(--font-display); font-size: .8rem; letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 18px; color: #7E947A;
  }
  .footer-col a { display: block; color: #D6E2D2; padding: 6px 0; font-size: .95rem; transition: color .18s ease; }
  .footer-col a:hover { color: #fff; }
  .footer-col .muted { color: #9FB39A; margin-bottom: 14px; font-size: .95rem; line-height: 1.6; }

  .footer-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    margin-top: 54px; padding-top: 26px;
    border-top: 1px solid rgba(255,255,255,.08);
    color: #7E947A; font-size: .86rem;
  }

  @media (max-width: 860px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-inner { grid-template-columns: 1fr; gap: 30px; }
  }
</style>
